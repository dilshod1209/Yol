rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isHardcodedAdmin() {
      return isAuthenticated() && 
        (request.auth.uid == "7YahvuqrUVghLlnigHp79vYiuUg2" ||
         request.auth.token.email == "dilshodallaberdiyev57@gmail.com" || 
         request.auth.token.email == "admin@road.ai");
    }

    function isAdmin() {
      return isHardcodedAdmin() || 
        (isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN');
    }

    match /{allPaths=**} {
      allow read, write: if isHardcodedAdmin();
    }

    match /users/{userId} {
      allow get: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow list: if isHardcodedAdmin() || isAdmin(); 
      allow create: if isAuthenticated() && isOwner(userId);
      allow update: if isHardcodedAdmin() || isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role);
      allow delete: if isHardcodedAdmin() || isAdmin();
    }

    match /reports/{reportId} {
      allow get, list: if isHardcodedAdmin() || isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isHardcodedAdmin() || isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow delete: if isHardcodedAdmin() || isAdmin();
    }

    match /notifications/{notificationId} {
      allow get, list: if isHardcodedAdmin() || isAdmin() || (isAuthenticated() && (resource.data.userId == request.auth.uid || resource.data.userId == 'global'));
      allow create: if isHardcodedAdmin() || isAdmin() || (isAuthenticated() && (request.resource.data.userId == 'admin' || request.resource.data.userId == request.auth.uid));
      allow update: if isHardcodedAdmin() || isAdmin() || (isAuthenticated() && (resource.data.userId == request.auth.uid || resource.data.userId == 'global') && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']));
      allow delete: if isHardcodedAdmin() || isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }

    match /test/{docId} {
      allow read: if true;
    }
  }
}
